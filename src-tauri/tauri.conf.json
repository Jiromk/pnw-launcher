{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "PNW Launcher",
  "version": "1.0.4",
  "identifier": "com.pnw.launcher",

  "build": {
    "beforeDevCommand": "vite",
    "beforeBuildCommand": "vite build",
    "devUrl": "http://localhost:5174",
    "frontendDist": "../dist"  
  },

  "app": {
    "windows": [
      {
        "title": "Pokémon New World — Launcher",
        "width": 1280,
        "height": 950,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": { "enable": true, "scope": ["**"] },
      "capabilities": ["default"]
    }
  },

  "plugins": {
    "updater": {
      "endpoints": [
        "https://pokemonnewworld.com/api/downloads/launcher-update?target={{target}}&arch={{arch}}&current_version={{current_version}}"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM1NTgwNzZENTE3MzVCNEIKUldSTFczTlJiUWRZeGFyVkFXUHQ2R3NnRHYzMnZtMDAxVlQrcFdwQlpQN0R4b1pacngrZlVMZGoK"
    }
  },

  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "headerImage": null,
        "sidebarImage": null,
        "installMode": "currentUser",
        "languages": ["French", "English"],
        "startMenuFolder": "Pokemon New World",
        "installerHooks": "bundler/nsis/hooks.nsh"
      }
    }
  }
}
